# ═══════════════════════════════════════
# AYANA Care Companion — Environment Config
# Copy to .env and fill in your values
# ═══════════════════════════════════════

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# WhatsApp — Twilio Sandbox (Day 1-3 dev)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_PROVIDER=twilio

# WhatsApp — Meta Cloud API (switch to this for production)
# META_WHATSAPP_TOKEN=your-meta-token
# META_PHONE_NUMBER_ID=your-phone-number-id
# META_VERIFY_TOKEN=your-webhook-verify-token
# WHATSAPP_PROVIDER=meta

# Sarvam AI
SARVAM_API_KEY=your-sarvam-api-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Twilio Voice (for emergency calls)
TWILIO_VOICE_PHONE=+1234567890
NEXT_PUBLIC_WHATSAPP_BOT_NUMBER=14155238886

# App
APP_URL=https://your-app.railway.app
ADMIN_PASSWORD=changethis
TIMEZONE=Asia/Kolkata
